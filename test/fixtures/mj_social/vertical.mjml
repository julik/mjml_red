<mjml>
  <mj-body>
    <mj-section>
      <mj-column>
        <mj-social font-size="15px" icon-size="30px" mode="vertical">
          <mj-social-element name="facebook" href="https://facebook.com/example">
            Facebook
          </mj-social-element>
          <mj-social-element name="twitter" href="https://twitter.com/example">
            Twitter
          </mj-social-element>
        </mj-social>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
